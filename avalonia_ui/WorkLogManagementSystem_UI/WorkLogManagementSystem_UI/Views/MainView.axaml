<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WorkLogManagementSystem_UI.ViewModels"
             xmlns:models="clr-namespace:WorkLogManagementSystem_UI.Models"
             mc:Ignorable="d"
             d:DesignWidth="1180"
             d:DesignHeight="760"
             x:Class="WorkLogManagementSystem_UI.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}"/>
      <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppPanelBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16"/>
    </Style>
    <Style Selector="TextBox">
      <Setter Property="InputMethod.IsInputMethodEnabled" Value="True"/>
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource AppPrimaryBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppOnAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppPrimaryBrush}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.toolbar">
      <Setter Property="Background" Value="{DynamicResource AppToolbarButtonBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppToolbarButtonForegroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppToolbarButtonBackgroundBrush}"/>
      <Setter Property="Padding" Value="10,7"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.icon-toolbar">
      <Setter Property="Background" Value="{DynamicResource AppToolbarButtonBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppToolbarButtonForegroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppToolbarButtonBackgroundBrush}"/>
      <Setter Property="Width" Value="38"/>
      <Setter Property="Height" Value="38"/>
      <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="Button.icon-toolbar-accent">
      <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppOnAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="Width" Value="38"/>
      <Setter Property="Height" Value="38"/>
      <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="Button.toolbar-accent">
      <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppOnAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
      <Setter Property="Padding" Value="10,7"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="{DynamicResource AppDangerBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppOnAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppDangerBrush}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.fit">
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="MinWidth" Value="0"/>
      <Setter Property="Padding" Value="8,7"/>
    </Style>
    <Style Selector="Button.topbar-action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppTopActionHoverBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppOnAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppTopActionHoverBorderBrush}"/>
    </Style>

    <Style Selector="Button.topbar-action:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppTopActionPressedBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppOnAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppTopActionHoverBorderBrush}"/>
    </Style>

    <Style Selector="Button.topbar-action-accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppAccentHoverBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppOnAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppTopActionAccentHoverBorderBrush}"/>
    </Style>

    <Style Selector="Button.topbar-action-accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AppAccentPressedBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppOnAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppTopActionAccentHoverBorderBrush}"/>
    </Style>
    <Style Selector="TextBox.editor">
      <Setter Property="MinHeight" Value="100"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="AcceptsReturn" Value="True"/>
    </Style>
    <Style Selector="CalendarDatePicker.date-input">
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="MinWidth" Value="170"/>
      <Setter Property="SelectedDateFormat" Value="Custom"/>
      <Setter Property="CustomDateFormatString" Value="yyyy-MM-dd"/>
    </Style>
    <Style Selector="Border.modal-card">
      <Setter Property="Background" Value="{DynamicResource AppPageBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppPanelBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="20"/>
      <Setter Property="MaxWidth" Value="460"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Border.modal-scrim">
      <Setter Property="Background" Value="#99000000"/>
      <Setter Property="Padding" Value="12"/>
    </Style>
  </UserControl.Styles>

  <ThemeVariantScope x:Name="RootThemeScope"
                     RequestedThemeVariant="{Binding ActiveThemeVariant}">
  <Grid Background="{DynamicResource AppPageBackgroundBrush}" RowDefinitions="Auto,*">
    <Border x:Name="TopBar"
            Grid.Row="0"
            Background="{DynamicResource AppTopBarBrush}"
            Padding="10,8"
            IsVisible="{Binding IsBackendConnected}">
      <Grid x:Name="TopBarShell"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="12"
            VerticalAlignment="Center">
        <WrapPanel x:Name="TopBarInfoGroup"
                   Grid.Column="0"
                   Orientation="Horizontal"
                   VerticalAlignment="Center">
          <Button x:Name="TaskPaneToggleButton"
                  Classes="icon-toolbar topbar-action"
                  Margin="0,0,8,0"
                  Click="OnTaskPaneToggleClicked"
                  IsVisible="False"
                  ToolTip.Tip="과업">
            <PathIcon Width="18"
                      Height="18"
                      Data="M4 6H20V8H4V6ZM4 11H20V13H4V11ZM4 16H20V18H4V16Z"/>
          </Button>
          <TextBlock x:Name="AppTitleText"
                     Text="업무일지 관리체계"
                     Foreground="{DynamicResource AppTopBarTextBrush}"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Margin="0,0,10,0"
                     VerticalAlignment="Center"/>
          <TextBlock x:Name="CurrentScopeText"
                     Text="{Binding CurrentScopeLabel}"
                     Foreground="{DynamicResource AppTopBarMutedBrush}"
                     Margin="0,0,10,0"
                     VerticalAlignment="Center"/>
          <TextBlock Text="{Binding CurrentUsername}"
                     Foreground="{DynamicResource AppTopBarMutedBrush}"
                     VerticalAlignment="Center"
                     IsVisible="{Binding IsLoggedInStatusVisible}"/>
        </WrapPanel>

        <StackPanel x:Name="TopBarActionGroup"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
	          <Button x:Name="SettingsButton"
                  Classes="icon-toolbar topbar-action"
                  Command="{Binding OpenSettingsCommand}"
                  ToolTip.Tip="설정"
                  Click="OnTaskPaneMenuActionClicked">
            <PathIcon Width="18"
                      Height="18"
                      Data="M19.43 12.98C19.47 12.66 19.5 12.34 19.5 12C19.5 11.66 19.47 11.33 19.42 11.02L21.54 9.37C21.73 9.22 21.78 8.95 21.66 8.73L19.66 5.27C19.54 5.05 19.29 4.96 19.06 5.05L16.56 6.06C16.04 5.66 15.5 5.32 14.88 5.07L14.5 2.42C14.47 2.18 14.25 2 14 2H10C9.75 2 9.54 2.18 9.5 2.42L9.12 5.07C8.5 5.32 7.96 5.66 7.44 6.06L4.94 5.05C4.71 4.96 4.46 5.05 4.34 5.27L2.34 8.73C2.21 8.95 2.27 9.22 2.46 9.37L4.58 11.02C4.53 11.33 4.5 11.67 4.5 12C4.5 12.33 4.53 12.66 4.58 12.98L2.46 14.63C2.27 14.78 2.22 15.05 2.34 15.27L4.34 18.73C4.46 18.95 4.71 19.04 4.94 18.95L7.44 17.94C7.96 18.34 8.5 18.68 9.12 18.93L9.5 21.58C9.54 21.82 9.75 22 10 22H14C14.25 22 14.47 21.82 14.5 21.58L14.88 18.93C15.5 18.68 16.04 18.34 16.56 17.94L19.06 18.95C19.29 19.04 19.54 18.95 19.66 18.73L21.66 15.27C21.78 15.05 21.73 14.78 21.54 14.63L19.43 12.98ZM12 15.5C10.07 15.5 8.5 13.93 8.5 12C8.5 10.07 10.07 8.5 12 8.5C13.93 8.5 15.5 10.07 15.5 12C15.5 13.93 13.93 15.5 12 15.5Z"/>
	          </Button>
	          <Button Classes="toolbar topbar-action"
	                  Content="로그아웃"
	                  Command="{Binding LogoutCommand}"/>
	          <Button x:Name="RefreshButton"
                  Classes="icon-toolbar topbar-action"
                  Command="{Binding LoadTasksCommand}"
                  ToolTip.Tip="새로고침"
                  Click="OnTaskPaneMenuActionClicked">
            <PathIcon Width="18"
                      Height="18"
                      Data="M17.65 6.35C16.2 4.9 14.21 4 12 4C7.58 4 4.01 7.58 4.01 12C4.01 16.42 7.58 20 12 20C15.73 20 18.84 17.45 19.73 14H17.65C16.83 16.33 14.61 18 12 18C8.69 18 6 15.31 6 12C6 8.69 8.69 6 12 6C13.66 6 15.14 6.69 16.22 7.78L13 11H20V4L17.65 6.35Z"/>
          </Button>
          <Button x:Name="ExportButton"
                  Classes="icon-toolbar-accent topbar-action-accent"
                  Command="{Binding ExportExcelCommand}"
                  ToolTip.Tip="엑셀 내보내기"
                  Click="OnTaskPaneMenuActionClicked">
            <PathIcon Width="18"
                      Height="18"
                      Data="M5 20H19V18H5V20ZM19 9H15V3H9V9H5L12 16L19 9Z"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          IsVisible="{Binding IsBackendConnected}">
      <Grid x:Name="ResponsiveShell"
            ColumnDefinitions="360,*"
            RowDefinitions="*"
            Margin="16"
            ColumnSpacing="16">
        <Border x:Name="TaskPaneOverlay"
                Grid.Column="0"
                Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="#66000000"
                IsVisible="False"
                PointerPressed="OnTaskPaneOverlayPressed"/>
        <Border x:Name="TaskListPanel"
                Grid.Column="0"
                Grid.Row="0"
                Classes="panel"
                VerticalAlignment="Stretch">
          <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top"
                        Spacing="14">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Classes="section-title"
                           Text="날짜별 과업"/>
                <Button x:Name="TaskPaneCloseButton"
                        Grid.Column="1"
                        Classes="icon-toolbar"
                        Width="34"
                        Height="34"
                        Padding="0"
                        Click="OnTaskPaneCloseClicked"
                        IsVisible="False"
                        ToolTip.Tip="닫기">
                  <PathIcon Width="18"
                            Height="18"
                            Data="M18.3 5.71L16.89 4.29L12 9.17L7.11 4.29L5.7 5.71L10.59 10.59L5.7 15.48L7.11 16.9L12 12L16.89 16.9L18.3 15.48L13.41 10.59L18.3 5.71Z"/>
                </Button>
              </Grid>

              <Grid RowDefinitions="Auto,Auto"
                    RowSpacing="8">
                <CalendarDatePicker x:Name="TaskListDatePicker"
                                    Grid.Row="0"
                                    Classes="date-input"
                                    SelectedDate="{Binding SelectedDate, Mode=TwoWay}"/>
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">
                  <Button Grid.Column="0"
                          Classes="fit"
                          Content="전일"
                          Command="{Binding MovePreviousDayCommand}"/>
                  <Button Grid.Column="1"
                          Classes="fit"
                          Content="오늘"
                          Command="{Binding MoveTodayCommand}"/>
                  <Button Grid.Column="2"
                          Classes="fit"
                          Content="익일"
                          Command="{Binding MoveNextDayCommand}"/>
                </Grid>
              </Grid>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="8">
                <Button Grid.Column="0"
                        Classes="primary fit"
                        Content="최상위 과업 추가"
                        Command="{Binding NewRootTaskCommand}"/>
                <Button Grid.Column="1"
                        Classes="fit"
                        Content="하위 과업 추가"
                        Command="{Binding NewChildTaskCommand}"/>
              </Grid>

            </StackPanel>

            <Border x:Name="TaskPaneActionStrip"
                    DockPanel.Dock="Bottom"
                    Background="{DynamicResource AppTopBarBrush}"
                    CornerRadius="8"
                    Padding="10,8"
                    Margin="0,14,0,0"
                    IsVisible="False">
              <ContentControl x:Name="TaskPaneActionHost"
                              HorizontalAlignment="Right"/>
            </Border>

            <TreeView Margin="0,18,0,0"
                      ItemsSource="{Binding Tasks}"
                      SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
              <TreeView.DataTemplates>
                <TreeDataTemplate DataType="models:TaskDto"
                                  ItemsSource="{Binding Children}">
                  <Grid ColumnDefinitions="*"
                        MinHeight="46"
                        Margin="0,4">
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="{Binding Title}"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource AppTextPrimaryBrush}"
                                 TextTrimming="CharacterEllipsis"/>
	                      <TextBlock Text="{Binding DateSummary}"
	                                 FontSize="12"
	                                 Foreground="{DynamicResource AppTextSecondaryBrush}"/>
	                      <TextBlock Text="{Binding PrioritySummary}"
	                                 FontSize="12"
	                                 Foreground="{DynamicResource AppTextSecondaryBrush}"/>
	                    </StackPanel>
                  </Grid>
                </TreeDataTemplate>
              </TreeView.DataTemplates>
            </TreeView>
          </DockPanel>
        </Border>

        <Border x:Name="EditorPanel"
                Grid.Column="1"
                Grid.Row="0"
                Classes="panel"
                VerticalAlignment="Stretch">
          <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="section-title"
                           Text="{Binding EditorModeLabel}"/>
                <TextBlock Text="{Binding EditorParentTitleLabel}"
                           Foreground="{DynamicResource AppTextSecondaryBrush}"
                           IsVisible="{Binding HasEditorParentTitle}"/>
              </StackPanel>

              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="8">
                <Button Content="삭제"
                        Classes="danger"
                        IsEnabled="{Binding CanEditExistingTask}"
                        Command="{Binding DeleteTaskCommand}"/>
                <Button Content="저장"
                        Classes="primary"
                        IsEnabled="{Binding IsEditorEnabled}"
                        Command="{Binding SaveTaskCommand}"/>
              </StackPanel>
            </Grid>

            <ScrollViewer Margin="0,18,0,0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="14"
                          IsEnabled="{Binding IsEditorEnabled}">
	                <StackPanel>
	                  <TextBlock Classes="label"
	                             Text="제목"/>
	                  <TextBox Text="{Binding EditorTitle}"
	                           Watermark="과업 제목"/>
	                </StackPanel>

	                <StackPanel>
	                  <TextBlock Classes="label"
	                             Text="우선순위"/>
	                  <NumericUpDown Minimum="0"
	                                 Maximum="255"
	                                 Increment="1"
	                                 Value="{Binding EditorPriority, Mode=TwoWay}"/>
	                </StackPanel>

                <Grid x:Name="EditorDateGrid"
                      ColumnDefinitions="*,*,*"
                      RowDefinitions="Auto"
                      ColumnSpacing="10"
                      RowSpacing="10">
                  <StackPanel x:Name="StartDatePanel"
                              Grid.Column="0">
                    <TextBlock Classes="label"
                               Text="시작일"/>
                    <CalendarDatePicker Classes="date-input"
                                        SelectedDate="{Binding EditorStartDate, Mode=TwoWay}"/>
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="8"
                          Margin="0,8,0,0">
                      <Button Grid.Column="0"
                              Classes="fit"
                              Content="오늘"
                              Command="{Binding SetStartTodayCommand}"/>
                      <Button Grid.Column="1"
                              Classes="fit"
                              Content="태초"
                              Command="{Binding SetStartUnboundedCommand}"/>
                    </Grid>
                  </StackPanel>

                  <StackPanel x:Name="DueDatePanel"
                              Grid.Column="1">
                    <TextBlock Classes="label"
                               Text="마감일"/>
                    <CalendarDatePicker Classes="date-input"
                                        SelectedDate="{Binding EditorDueDate, Mode=TwoWay}"/>
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="8"
                          Margin="0,8,0,0">
                      <Button Grid.Column="0"
                              Classes="fit"
                              Content="오늘"
                              Command="{Binding SetDueTodayCommand}"/>
                      <Button Grid.Column="1"
                              Classes="fit"
                              Content="영구"
                              Command="{Binding SetDueUnboundedCommand}"/>
                    </Grid>
                  </StackPanel>

                  <StackPanel x:Name="ActualEndDatePanel"
                              Grid.Column="2">
                    <TextBlock Classes="label"
                               Text="실제 종료일"/>
                    <CalendarDatePicker Classes="date-input"
                                        SelectedDate="{Binding EditorActualEndDate, Mode=TwoWay}"/>
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="8"
                          Margin="0,8,0,0">
                      <Button Grid.Column="0"
                              Classes="fit"
                              Content="오늘"
                              Command="{Binding SetActualEndTodayCommand}"/>
                      <Button Grid.Column="1"
                              Classes="fit"
                              Content="미완료"
                              Command="{Binding ClearActualEndCommand}"/>
                    </Grid>
                  </StackPanel>
                </Grid>

                <StackPanel>
                  <TextBlock Classes="label"
                             Text="과업내용"/>
                  <TextBox Classes="editor"
                           Text="{Binding EditorContent}"
                           Watermark="과업의 목적, 범위, 기준, 산출물을 적으세요."/>
                </StackPanel>

                <StackPanel>
                  <TextBlock Classes="label"
                             Text="선택 일자의 수행내용"/>
                  <TextBox Classes="editor"
                           Text="{Binding EditorPerformedContent}"
                           Watermark="선택한 날짜에 실제 수행한 내용을 적으세요."/>
                </StackPanel>

                <StackPanel>
                  <TextBlock Classes="label"
                             Text="선택 일자의 회고"/>
                  <TextBox Classes="editor"
                           Text="{Binding EditorDailyRetrospective}"
                           Watermark="선택한 날짜의 잘 된 점, 막힌 점, 다음 액션을 적으세요."/>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>
    </Grid>

    <Border Grid.RowSpan="2"
            Classes="modal-scrim"
            ZIndex="20"
            IsVisible="{Binding IsSettingsDialogOpen}">
      <Border x:Name="SettingsModalCard"
              Classes="modal-card">
        <StackPanel Spacing="16">
          <TextBlock Text="설정"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource AppTextPrimaryBrush}"/>

          <StackPanel>
            <TextBlock Classes="label"
                       Text="API 주소"/>
            <TextBox Text="{Binding SettingsApiBaseUrl, Mode=TwoWay}"
                     Watermark="http://localhost:8000"/>
          </StackPanel>

          <StackPanel>
            <TextBlock Classes="label"
                       Text="테마"/>
            <StackPanel Orientation="Horizontal"
                        Spacing="12">
              <RadioButton GroupName="MainSettingsThemeMode"
                           Content="시스템"
                           IsChecked="{Binding SettingsUseSystemTheme, Mode=TwoWay}"/>
              <RadioButton GroupName="MainSettingsThemeMode"
                           Content="라이트"
                           IsChecked="{Binding SettingsUseLightTheme, Mode=TwoWay}"/>
              <RadioButton GroupName="MainSettingsThemeMode"
                           Content="다크"
                           IsChecked="{Binding SettingsUseDarkTheme, Mode=TwoWay}"/>
            </StackPanel>
          </StackPanel>

          <TextBlock Text="{Binding SettingsErrorMessage}"
                     Foreground="{DynamicResource AppErrorBrush}"
                     TextWrapping="Wrap"
                     IsVisible="{Binding HasSettingsErrorMessage}"/>

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button Content="취소"
                    Command="{Binding CancelSettingsCommand}"/>
            <Button Classes="primary"
                    Content="저장"
                    Command="{Binding SaveSettingsCommand}"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

    <Border Grid.RowSpan="2"
            Classes="modal-scrim"
            ZIndex="21"
            IsVisible="{Binding IsExportRangeDialogOpen}">
      <Border Classes="modal-card">
        <StackPanel Spacing="16">
          <TextBlock Text="엑셀 내보내기"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource AppTextPrimaryBrush}"/>

          <StackPanel Spacing="10">
            <StackPanel>
              <TextBlock Classes="label"
                         Text="시작일"/>
              <CalendarDatePicker Classes="date-input"
                                  SelectedDate="{Binding ExportStartDate, Mode=TwoWay}"/>
            </StackPanel>

            <StackPanel>
              <TextBlock Classes="label"
                         Text="종료일"/>
              <CalendarDatePicker Classes="date-input"
                                  SelectedDate="{Binding ExportEndDate, Mode=TwoWay}"/>
            </StackPanel>
          </StackPanel>

          <TextBlock Text="{Binding ExportRangeErrorMessage}"
                     Foreground="{DynamicResource AppErrorBrush}"
                     TextWrapping="Wrap"
                     IsVisible="{Binding HasExportRangeErrorMessage}"/>

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button Content="취소"
                    Command="{Binding CancelExportRangeCommand}"/>
            <Button Classes="primary"
                    Content="내보내기"
                    Command="{Binding ConfirmExportExcelCommand}"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

    <Border Grid.RowSpan="2"
            Classes="modal-scrim"
            ZIndex="22"
            IsVisible="{Binding IsConnectionErrorDialogOpen}">
      <Border Classes="modal-card"
              MaxWidth="520"
              MaxHeight="420">
        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="16">
          <TextBlock Text="연결 실패"
                     Grid.Row="0"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource AppTextPrimaryBrush}"/>
          <ScrollViewer Grid.Row="1"
                        MaxHeight="260"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <TextBlock Text="{Binding ConnectionErrorMessage}"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       TextWrapping="Wrap"/>
          </ScrollViewer>
          <StackPanel Orientation="Horizontal"
                      Grid.Row="2"
                      HorizontalAlignment="Right">
            <Button Classes="primary"
                    Content="확인"
                    Command="{Binding DismissConnectionErrorCommand}"/>
          </StackPanel>
        </Grid>
      </Border>
    </Border>

    <Border Grid.RowSpan="2"
            Background="{DynamicResource AppPageBackgroundBrush}"
            Padding="18"
            ZIndex="30"
            IsVisible="{Binding IsConnectionGateVisible}">
      <Border Classes="modal-card"
              MaxWidth="560">
        <StackPanel Spacing="18">
	          <StackPanel Spacing="4">
	            <TextBlock Text="로그인"
	                       FontSize="24"
	                       FontWeight="SemiBold"
	                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
	            <TextBlock Text="업무일지 백엔드 주소와 계정을 입력하세요."
	                       Foreground="{DynamicResource AppTextSecondaryBrush}"
	                       TextWrapping="Wrap"/>
	          </StackPanel>

          <StackPanel>
            <TextBlock Classes="label"
                       Text="API 주소"/>
	            <TextBox Text="{Binding ConnectionGateApiBaseUrl, Mode=TwoWay}"
	                     Watermark="http://192.168.0.14:8000"/>
	          </StackPanel>

	          <StackPanel>
	            <TextBlock Classes="label"
	                       Text="아이디"/>
		            <TextBox Text="{Binding LoginUsername, Mode=TwoWay}"
		                     Watermark="admin"/>
	          </StackPanel>

	          <StackPanel>
	            <TextBlock Classes="label"
	                       Text="비밀번호"/>
	            <TextBox Text="{Binding LoginPassword, Mode=TwoWay}"
	                     PasswordChar="*"/>
	          </StackPanel>

          <CheckBox Content="계정정보 저장"
                    IsChecked="{Binding RememberCredentials, Mode=TwoWay}"
                    IsEnabled="{Binding IsCredentialSaveSupported}"/>
          <TextBlock Text="{Binding CredentialSaveUnsupportedReason}"
                     Foreground="{DynamicResource AppTextMutedBrush}"
                     FontSize="12"
                     TextWrapping="Wrap"
                     IsVisible="{Binding IsCredentialSaveUnsupported}"/>

          <TextBlock Text="{Binding ConnectionGateErrorMessage}"
                     Foreground="{DynamicResource AppErrorBrush}"
                     TextWrapping="Wrap"
                     IsVisible="{Binding HasConnectionGateErrorMessage}"/>

          <TextBlock Text="연결 확인 중..."
                     Foreground="{DynamicResource AppTextSecondaryBrush}"
                     IsVisible="{Binding IsConnectionBusy}"/>

	          <StackPanel Orientation="Horizontal"
	                      HorizontalAlignment="Right"
	                      Spacing="8">
	            <Button Content="서버 확인"
	                    Command="{Binding ConnectToBackendCommand}"/>
	            <Button Classes="primary"
	                    Content="로그인"
	                    Command="{Binding LoginCommand}"/>
	          </StackPanel>
        </StackPanel>
      </Border>
    </Border>
  </Grid>
  </ThemeVariantScope>
</UserControl>
