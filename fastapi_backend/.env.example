WORKLOG_APP_TITLE=Work Log Management System
WORKLOG_APP_VERSION=0.1.0
WORKLOG_CORS_ORIGINS=*
WORKLOG_CORS_ALLOW_CREDENTIALS=true
# Optional. Built-in admin is disabled unless both values are set.
WORKLOG_ADMIN_USERNAME=
WORKLOG_ADMIN_PASSWORD=
# Optional. If empty, a random key is generated at app startup and old tokens expire on restart.
WORKLOG_JWT_SECRET_KEY=
WORKLOG_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
WORKLOG_DATABASE_URL=

# MariaDB:
# WORKLOG_DATABASE_URL=mariadb+mariadbconnector://user:password@127.0.0.1:3306/worklog?charset=utf8mb4
